---
import HomeHeader from "@components/layout/HomeHeader.astro";
import Container from "@components/ui/Container.astro";
---

<section
  id="inicio"
  class="relative min-h-screen overflow-hidden bg-[#d9d3cb] text-white"
>
  <div class="hero-prelude" aria-hidden="true">
    <img class="hero-prelude__logo" src="/images/logo.svg" alt="" />
  </div>

  <img
    alt="Torre del Oro y el Guadalquivir en Sevilla"
    class="absolute inset-0 h-full w-full scale-[1.06] object-cover object-center blur-[3px] brightness-[0.72]"
    loading="eager"
    src="/images/torre-del-oro.jpg"
  />

  <div
    class="absolute inset-0 bg-[linear-gradient(180deg,rgba(2,14,18,0.42),rgba(2,14,18,0.68)),linear-gradient(90deg,rgba(2,14,18,0.54),rgba(2,14,18,0.24)_45%,rgba(2,14,18,0.46)),radial-gradient(circle_at_top_left,rgba(255,255,255,0.12),transparent_30%)]"
  >
  </div>
  <HomeHeader />

  <Container
    className="relative z-10 flex min-h-screen max-w-[88rem] items-center px-5 py-28 sm:px-8 sm:py-32 lg:px-10 lg:py-36"
  >
    <div class="w-full lg:pt-12">
      <div class="hero-content max-w-4xl space-y-6 sm:space-y-7">
        <p
          class="text-[0.68rem] font-medium tracking-[0.36em] text-white/76 uppercase sm:text-[0.72rem]"
        >
          Ingeniero de software · Inteligencia artificial
        </p>

        <h1
          class="max-w-4xl font-serif text-[2.85rem] leading-[1] font-normal tracking-[-0.045em] text-white sm:text-[3.85rem] lg:text-[4.75rem]"
        >
          Javier Muñoz Romero
        </h1>

        <p
          class="max-w-2xl text-[1rem] leading-7 text-white/84 sm:text-[1.05rem] sm:leading-8 lg:text-[1.12rem]"
        >
          Grado en Ingeniería Informática-Ingeniería del Software y Máster
          universitario en Ciencia de Datos.
        </p>
      </div>
    </div>
  </Container>
</section>
