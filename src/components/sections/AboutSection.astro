---
import BadgeList from "@components/ui/BadgeList.astro";
import Container from "@components/ui/Container.astro";
import PlaceholderVisual from "@components/ui/PlaceholderVisual.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";
import { homeContent } from "@data/site";

const { about } = homeContent;
---

<section id="sobre-mi" class="section-shell section-divider">
  <Container>
    <div class="grid gap-12 lg:grid-cols-[minmax(18rem,0.9fr)_minmax(0,1.1fr)] lg:items-start">
      <PlaceholderVisual
        label={about.visualLabel}
        className="about-visual min-h-[22rem] lg:min-h-[30rem]"
      />

      <div class="space-y-10">
        <SectionHeading
          eyebrow={about.eyebrow}
          title={about.title}
          description={about.description}
        />

        <div class="grid gap-8 lg:grid-cols-2">
          <article class="space-y-4">
            <h3 class="meta-title">{about.bioTitle}</h3>
            <p class="muted-copy">{about.bio}</p>
          </article>

          <article class="space-y-4">
            <h3 class="meta-title">{about.detailsTitle}</h3>
            <dl class="space-y-3 text-sm text-[var(--color-text-muted)]">
              {
                about.details.map((item) => (
                  <div class="editorial-row">
                    <dt>{item.label}</dt>
                    <dd class="text-[var(--color-text)]">{item.value}</dd>
                  </div>
                ))
              }
            </dl>
          </article>
        </div>

        <div class="grid gap-8 lg:grid-cols-2">
          <article class="space-y-4">
            <h3 class="meta-title">{about.technologiesTitle}</h3>
            <BadgeList items={about.technologies} />
          </article>

          <article class="space-y-4">
            <h3 class="meta-title">{about.experienceTitle}</h3>
            <ul class="space-y-3 text-sm text-[var(--color-text-muted)]">
              {
                about.experience.map((item) => (
                  <li class="editorial-row">{item}</li>
                ))
              }
            </ul>
          </article>
        </div>
      </div>
    </div>
  </Container>
</section>
