---
import Container from "@components/ui/Container.astro";
import PlaceholderVisual from "@components/ui/PlaceholderVisual.astro";
import { homeContent } from "@data/site";

const { hero } = homeContent;
---

<section id="inicio" class="section-shell pt-8 sm:pt-12">
  <Container>
    <div class="hero-editorial-shell">
      <div class="grid gap-14 lg:grid-cols-[17rem_minmax(0,1fr)_minmax(18rem,0.9fr)] lg:items-center">
        <div class="order-2 flex justify-center lg:order-1 lg:justify-start">
          <PlaceholderVisual
            label={hero.visualLabel}
            className="hero-portrait min-h-[12.5rem] min-w-[12.5rem] rounded-full"
          />
        </div>

        <div class="order-1 space-y-8 text-center lg:order-2 lg:text-left">
          <div class="space-y-5 animate-enter">
            <p class="eyebrow">{hero.eyebrow}</p>
            <div class="space-y-4">
              <h1 class="display-title">{hero.name}</h1>
              <p class="hero-role text-xl uppercase sm:text-2xl">{hero.role}</p>
            </div>
            <p class="lead-copy mx-auto max-w-2xl lg:mx-0">{hero.description}</p>
          </div>

          <div class="flex flex-col items-center justify-center gap-3 sm:flex-row lg:justify-start">
            <a class="button-primary" href={hero.primaryAction.href}>
              {hero.primaryAction.label}
            </a>
            <a class="button-secondary" href={hero.secondaryAction.href}>
              {hero.secondaryAction.label}
            </a>
          </div>

          <div class="flex flex-wrap items-center justify-center gap-4 text-xs tracking-[0.18em] text-[var(--color-text-muted)] uppercase lg:justify-start">
            {
              hero.socialLinks.map((link) => (
                <a class="social-minimal-link" href={link.href}>{link.label}</a>
              ))
            }
          </div>
        </div>

        <PlaceholderVisual
          label="ELEMENTO_VISUAL_MINIMAL"
          className="order-3 min-h-[24rem] rounded-[0.2rem] bg-white/40 lg:min-h-[28rem]"
        />
      </div>
    </div>
  </Container>
</section>
