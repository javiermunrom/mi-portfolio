---
import Container from "@components/ui/Container.astro";
---

<section class="border-b border-slate-200 py-16 sm:py-20">
  <Container>
    <div class="max-w-3xl space-y-6">
      <p class="text-sm font-medium tracking-[0.2em] text-slate-500 uppercase">
        Portfolio profesional
      </p>
      <h1 class="text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">
        Base sólida para presentar proyectos, experiencia y evolución
        profesional.
      </h1>
      <p class="text-base leading-7 text-slate-600 sm:text-lg">
        Este proyecto prioriza arquitectura, mantenibilidad y escalabilidad para
        que el contenido crezca sin rehacer la base.
      </p>
    </div>
  </Container>
</section>
