---
import Container from "@components/ui/Container.astro";

const featuredProjects = [
  {
    label: "Proyecto 01",
    category: "Software · IA",
    year: "2025",
    title: "Título provisional para proyecto destacado",
    summary:
      "Texto de apoyo provisional para describir el enfoque general del proyecto, su contexto técnico y el tipo de solución desarrollada.",
    details: ["Sistema", "Datos", "Automatización"],
  },
  {
    label: "Proyecto 02",
    category: "Machine Learning",
    year: "2025",
    title: "Segundo proyecto destacado con contenido pendiente",
    summary:
      "Bloque de texto temporal para marcar cómo quedará una descripción breve, clara y centrada en el valor técnico del proyecto.",
    details: ["Modelos", "Pipeline", "Validación"],
  },
  {
    label: "Proyecto 03",
    category: "Producto · Software",
    year: "2025",
    title: "Tercer proyecto destacado en fase de definición",
    summary:
      "Contenido provisional para reservar espacio y ajustar la composición visual antes de incorporar la información definitiva.",
    details: ["Backend", "Integración", "UX"],
  },
];
---

<section
  id="proyectos"
  class="relative bg-[#f5f3ef] py-24 sm:py-28 lg:py-32"
>
  <Container className="max-w-[88rem] px-5 sm:px-8 lg:px-10">
    <div class="space-y-12">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1.1fr)_auto] lg:items-end">
        <div class="reveal max-w-5xl space-y-4">
          <p class="text-[0.7rem] tracking-[0.28em] text-[#020E12]/52 uppercase">
            Proyectos destacados
          </p>
          <h2 class="max-w-4xl text-[2.15rem] leading-[1.02] font-normal tracking-[-0.045em] text-[#020E12] sm:text-[2.9rem] lg:text-[3.35rem]">
            Una selección de trabajo aplicado en software, datos e inteligencia artificial.
          </h2>
          <p class="max-w-3xl text-[0.98rem] leading-7 text-[#020E12]/68 sm:text-[1.04rem]">
            Selección curada para presentar líneas de trabajo, enfoques técnicos y tipos de solución dentro del portfolio.
          </p>
        </div>

        <div class="reveal lg:justify-self-end" style="--delay: 0.08s;">
          <a
            class="inline-flex items-center gap-3 rounded-full border border-[#020E12]/12 px-6 py-3 text-[0.74rem] tracking-[0.22em] text-[#020E12]/76 uppercase transition duration-300 hover:border-[#020E12]/24 hover:text-[#020E12]"
            href="/projects"
          >
            <span>Ir a proyectos</span>
            <span>{">"}</span>
          </a>
        </div>
      </div>

      <div class="reveal h-px w-full bg-[#020E12]/10"></div>

      <div class="grid gap-5 lg:grid-cols-3 lg:gap-6">
        {
          featuredProjects.map((project, index) => (
            <article
              class="reveal flex h-full flex-col justify-between rounded-[1.8rem] border border-[#020E12]/10 bg-[#fbf9f5] p-5 sm:p-6"
              style={`--delay: ${index * 0.08}s;`}
            >
              <div class="space-y-6">
                <div class="flex items-start justify-between gap-4 border-b border-[#020E12]/10 pb-5">
                  <div class="space-y-2">
                    <p class="text-[0.68rem] tracking-[0.24em] text-[#020E12]/46 uppercase">
                      {project.label}
                    </p>
                    <div class="flex flex-wrap gap-x-3 gap-y-2 text-[0.72rem] tracking-[0.18em] text-[#020E12]/56 uppercase">
                      <span>{project.category}</span>
                      <span>{project.year}</span>
                    </div>
                  </div>
                  <span class="text-[#020E12]/24">0{index + 1}</span>
                </div>

                <div class="space-y-4">
                  <h3 class="text-[1.45rem] leading-[1.08] font-normal tracking-[-0.035em] text-[#020E12] sm:text-[1.7rem]">
                    {project.title}
                  </h3>
                  <p class="text-[0.98rem] leading-7 text-[#020E12]/68">
                    {project.summary}
                  </p>
                </div>
              </div>

              <div class="mt-8 space-y-5">
                <ul class="flex flex-wrap gap-x-3 gap-y-2 text-[0.7rem] tracking-[0.18em] text-[#020E12]/54 uppercase">
                  {project.details.map((detail) => <li>{detail}</li>)}
                </ul>

                <a
                  class="inline-flex items-center gap-3 text-[0.76rem] tracking-[0.22em] text-[#020E12]/72 uppercase transition duration-300 hover:text-[#020E12]"
                  href="/projects"
                >
                  <span>Ver proyecto</span>
                  <span>{">"}</span>
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </Container>
</section>
