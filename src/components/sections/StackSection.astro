---
import BadgeList from "@components/ui/BadgeList.astro";
import Container from "@components/ui/Container.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";
import { homeContent } from "@data/site";
---

<section id="stack" class="section-shell section-divider">
  <Container className="space-y-14">
    <SectionHeading
      eyebrow={homeContent.stackEyebrow}
      title={homeContent.stackTitle}
      description={homeContent.stackDescription}
      centered={true}
    />

    <div class="grid gap-x-8 gap-y-10 md:grid-cols-2 xl:grid-cols-4">
      {
        homeContent.stackCategories.map((category) => (
          <article class="editorial-stack-group space-y-5">
            <h3 class="card-title">{category.title}</h3>
            <BadgeList items={category.items} />
          </article>
        ))
      }
    </div>
  </Container>
</section>
