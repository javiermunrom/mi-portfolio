---
import BadgeList from "@components/ui/BadgeList.astro";
import Container from "@components/ui/Container.astro";
import PlaceholderVisual from "@components/ui/PlaceholderVisual.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";
import { homeContent } from "@data/site";
import type { ProjectEntry } from "@utils/projects";

interface Props {
  project: ProjectEntry;
}

const { project } = Astro.props;
---

<section class="section-shell">
  <Container className="space-y-10">
    <SectionHeading
      eyebrow={homeContent.featuredEyebrow}
      title={homeContent.featuredTitle}
      description={homeContent.featuredDescription}
    />

    <article class="grid gap-8 rounded-[2rem] border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-[var(--shadow-soft)] sm:p-8 lg:grid-cols-[minmax(18rem,0.95fr)_minmax(0,1.05fr)] lg:items-center">
      <PlaceholderVisual
        label={project.data.mediaLabel}
        className="min-h-[20rem] rounded-[1.75rem]"
      />

      <div class="space-y-6">
        <div class="space-y-3">
          <p class="eyebrow">PROYECTO_PRINCIPAL</p>
          <h3 class="section-title text-3xl sm:text-4xl">{project.data.title}</h3>
          <p class="lead-copy">{project.data.description}</p>
        </div>

        <BadgeList items={project.data.technologies} />

        <div class="flex flex-col gap-3 sm:flex-row">
          <a class="button-primary" href={`/projects/${project.id}/`}>
            VER_PROYECTO
          </a>
          <a class="button-secondary" href={project.data.githubUrl}>
            GITHUB
          </a>
        </div>
      </div>
    </article>
  </Container>
</section>
