---
import Container from "@components/ui/Container.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";
import { homeContent } from "@data/site";

const { contact } = homeContent;
---

<section id="contacto" class="section-shell pb-20 sm:pb-24">
  <Container className="space-y-12">
    <SectionHeading
      eyebrow={contact.eyebrow}
      title={contact.title}
      description={contact.description}
      centered={true}
    />

    <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.05fr)] lg:items-start">
      <div class="space-y-6">
        <div class="contact-map-placeholder">
          <div class="space-y-3 text-center">
            <p class="eyebrow text-white/60">MAP</p>
            <p class="text-lg font-medium tracking-[0.12em] text-white">
              {contact.mapLabel}
            </p>
          </div>
        </div>

        <div class="grid gap-4 md:grid-cols-3 lg:grid-cols-1">
          {
            contact.links.map((link) => (
              <a class="editorial-contact-link" href={link.href}>
                <p class="eyebrow">{link.label}</p>
                <p class="mt-3 text-base font-medium text-[var(--color-text)]">
                  {link.value}
                </p>
              </a>
            ))
          }
        </div>
      </div>

      <form class="editorial-form space-y-5" action="#" method="post">
        <h3 class="meta-title">{contact.formTitle}</h3>
        <input class="editorial-input" name="name" placeholder={contact.fields.name} type="text" />
        <input class="editorial-input" name="email" placeholder={contact.fields.email} type="email" />
        <textarea class="editorial-input min-h-40 resize-y" name="message" placeholder={contact.fields.message}></textarea>
        <button class="button-primary w-full sm:w-auto" type="button">
          {contact.fields.submit}
        </button>
      </form>
    </div>
  </Container>
</section>
