---
import projects from "../../data/projects.json";
import site from "../../data/site.json";
import ProjectsWorkspace from "./ProjectsWorkspace";

type Locale = "en" | "es";

const defaultLocale = site.shared.defaultLocale as Locale;
const assetBase = import.meta.env.BASE_URL;
---

<section id="projects" class="relative min-h-svh border-t border-white/10 bg-[#0d1117] text-[#f8fafc] lg:min-h-[175svh]">
  <div class="flex min-h-svh items-center overflow-hidden lg:sticky lg:top-0">
    <ProjectsWorkspace client:visible defaultLocale={defaultLocale} projects={projects} assetBase={assetBase} />
  </div>
</section>
