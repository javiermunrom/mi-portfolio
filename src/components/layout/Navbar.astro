---
import { navigationItems, siteConfig } from "@data/site";
---

<header class="mobile-topbar lg:hidden">
  <nav class="mx-auto flex w-full max-w-5xl items-center justify-between gap-6 px-5 py-5 sm:px-6 lg:px-8">
    <a class="nav-brand" href="/">{siteConfig.title}</a>
    <a class="button-secondary" href="#contacto">CONTACTAR</a>
  </nav>
</header>

<aside class="sidebar-shell hidden lg:flex">
  <div class="sidebar-inner">
    <a class="sidebar-brand" href="/">{siteConfig.title}</a>

    <nav class="sidebar-nav">
      <ul class="space-y-3 text-sm text-[var(--color-text-muted)]">
        {
          navigationItems.map((item) => (
            <li>
              <a class="sidebar-link transition duration-300 hover:text-[var(--color-text)]" href={item.href}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="sidebar-meta">
      <p>&copy; 2026 {siteConfig.title}</p>
      <p>BASE_EDITORIAL_MINIMAL</p>
    </div>
  </div>
</aside>
