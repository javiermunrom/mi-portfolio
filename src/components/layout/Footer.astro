---
import Container from "@components/ui/Container.astro";
import { footerContent } from "@data/site";
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-surface)]/72">
  <Container>
    <div class="flex flex-col gap-6 py-8 text-sm text-[var(--color-text-muted)] sm:flex-row sm:items-center sm:justify-between">
      <div class="space-y-2">
        <p>{footerContent.copyright}</p>
        <p>{footerContent.note}</p>
      </div>

      <div class="flex flex-wrap gap-5">
        {
          footerContent.links.map((link) => (
            <a class="transition duration-300 hover:text-[var(--color-text)]" href={link.href}>
              {link.label}
            </a>
          ))
        }
      </div>
    </div>
  </Container>
</footer>
