---
interface Props {
  label: string;
  className?: string;
}

const { label, className = "" } = Astro.props;
---

<div class:list={["placeholder-frame", className]}>
  <div class="space-y-3 text-center">
    <p class="eyebrow">VISUAL_PLACEHOLDER</p>
    <p class="text-lg font-medium tracking-[0.08em] text-[var(--color-text)]">
      {label}
    </p>
  </div>
</div>
