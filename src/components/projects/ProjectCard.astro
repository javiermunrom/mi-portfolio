---
import PlaceholderVisual from "@components/ui/PlaceholderVisual.astro";
import type { ProjectEntry } from "@utils/projects";

interface Props {
  project: ProjectEntry;
}

const { project } = Astro.props;
---

<article class="project-editorial-card flex h-full flex-col gap-5">
  <PlaceholderVisual
    label={project.data.mediaLabel}
    className="min-h-52 rounded-[0.2rem]"
  />

  <div class="flex flex-1 flex-col gap-4">
    <div class="flex items-start justify-between gap-4 border-b border-[var(--color-border)] pb-4">
      <div class="space-y-2">
        <p class="text-sm text-[var(--color-text-muted)]">
          {project.data.date.toLocaleDateString("es-ES")}
        </p>
        <h3 class="text-2xl font-semibold tracking-tight text-[var(--color-text)]">
          <a href={`/projects/${project.id}/`}>{project.data.title}</a>
        </h3>
      </div>
      {
        project.data.featured && <span class="badge-chip">Destacado</span>
      }
    </div>

    <p class="text-sm leading-6 text-[var(--color-text-muted)]">
      {project.data.description}
    </p>

    <ul class="flex flex-wrap gap-2 text-sm text-[var(--color-text-muted)]">
      {
        project.data.technologies.map((technology) => (
          <li class="project-tech-chip">{technology}</li>
        ))
      }
    </ul>

    <div class="mt-auto flex flex-wrap gap-5 text-sm font-medium tracking-[0.16em] text-[var(--color-text)] uppercase">
      <a class="project-link" href={`/projects/${project.id}/`}>VER_DETALLE</a>
      <a class="project-link" href={project.data.githubUrl}>GITHUB</a>
    </div>
  </div>
</article>
