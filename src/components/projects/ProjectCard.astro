---
import type { ProjectEntry } from "@utils/projects";

interface Props {
  project: ProjectEntry;
}

const { project } = Astro.props;
---

<article class="rounded-lg border border-slate-200 bg-white p-6">
  <div class="flex flex-col gap-4">
    <div class="flex items-start justify-between gap-4">
      <div>
        <p class="text-sm text-slate-500">
          {project.data.date.toLocaleDateString("es-ES")}
        </p>
        <h3 class="mt-2 text-xl font-semibold text-slate-900">
          <a href={`/projects/${project.id}/`}>{project.data.title}</a>
        </h3>
      </div>
      {
        project.data.featured && (
          <span class="rounded-full border border-slate-300 px-3 py-1 text-xs text-slate-600">
            Destacado
          </span>
        )
      }
    </div>

    <p class="text-sm leading-6 text-slate-600">{project.data.description}</p>

    <ul class="flex flex-wrap gap-2 text-sm text-slate-500">
      {
        project.data.technologies.map((technology) => (
          <li class="rounded-md bg-slate-100 px-2 py-1">{technology}</li>
        ))
      }
    </ul>

    <div class="flex flex-wrap gap-4 text-sm font-medium text-slate-700">
      <a class="hover:text-slate-900" href={`/projects/${project.id}/`}
        >Ver detalle</a
      >
      <a
        class="hover:text-slate-900"
        href={project.data.githubUrl}
        target="_blank"
        rel="noreferrer"
      >
        GitHub
      </a>
      <a
        class="hover:text-slate-900"
        href={project.data.demoUrl}
        target="_blank"
        rel="noreferrer"
      >
        Demo
      </a>
    </div>
  </div>
</article>
