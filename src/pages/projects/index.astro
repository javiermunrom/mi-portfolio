---
import ProjectCard from "@components/projects/ProjectCard.astro";
import Container from "@components/ui/Container.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";
import MainLayout from "@layouts/MainLayout.astro";
import { getProjects } from "@utils/projects";

const projects = await getProjects();
---

<MainLayout
  title="Proyectos"
  description="Listado placeholder de proyectos preparado para crecer."
  mainClass="layout-main flex-1"
>
  <section class="section-shell">
    <Container className="space-y-12">
      <SectionHeading
        eyebrow="COLECCION_PROYECTOS"
        title="PROYECTOS"
        description="LISTADO_MODULAR_CON_TARJETAS_REUTILIZABLES"
      />

      <div class="grid gap-x-8 gap-y-12 lg:grid-cols-2">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </Container>
  </section>
</MainLayout>
