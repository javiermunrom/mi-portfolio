---
import ProjectCard from "@components/projects/ProjectCard.astro";
import Container from "@components/ui/Container.astro";
import MainLayout from "@layouts/MainLayout.astro";
import { getProjects } from "@utils/projects";

const projects = await getProjects();
---

<MainLayout
  title="Proyectos"
  description="Listado de proyectos del portfolio con routing dinámico y contenido escalable."
>
  <section class="py-16 sm:py-20">
    <Container>
      <div class="max-w-3xl space-y-4">
        <p
          class="text-sm font-medium tracking-[0.2em] text-slate-500 uppercase"
        >
          Portfolio
        </p>
        <h1
          class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl"
        >
          Proyectos
        </h1>
        <p class="text-base leading-7 text-slate-600">
          Listado centralizado para navegar hacia la ficha individual de cada
          proyecto.
        </p>
      </div>

      <div class="mt-10 grid gap-6">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </Container>
  </section>
</MainLayout>
