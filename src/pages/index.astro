---
import AboutSection from "../components/AboutSection.astro";
import BackgroundParticles from "../components/BackgroundParticles.astro";
import ContactSection from "../components/ContactSection.astro";
import Hero from "../components/Hero.astro";
import ProjectsSection from "../components/ProjectsSection.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteNavbar from "../components/SiteNavbar.astro";
import "../styles/global.css";

import site from "../../data/site.json";

const locale = site.shared.defaultLocale;
const title = site[locale].siteName;
const googleAnalyticsId = import.meta.env.PROD ? import.meta.env.PUBLIC_GA_ID?.trim() : undefined;
---

<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/mi-portfolio/favicon.svg" />
    <title>{title}</title>
    {
      googleAnalyticsId && (
        <>
          <script async src={`https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsId}`}></script>
          <script is:inline define:vars={{ googleAnalyticsId }}>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
              dataLayer.push(arguments);
            }
            gtag("js", new Date());
            gtag("config", googleAnalyticsId);
          </script>
        </>
      )
    }
  </head>
  <body>
    <BackgroundParticles />
    <SiteNavbar />
    <Hero />
    <AboutSection />
    <ProjectsSection />
    <ContactSection />
    <SiteFooter />
  </body>
</html>
